{
  "name": "buildmind",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first, open-source vibe coding platform.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "apps/web",
    "packages/server"
  ],
  "bin": {
    "buildmind": "./packages/server/dist/start.js"
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --build",
    "dev:web": "npm run dev --workspace apps/web",
    "start": "node packages/server/dist/start.js"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitest/ui": "^4.1.9",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.9"
  }
}
